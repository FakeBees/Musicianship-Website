# Copy this file to .env for local development.
# .env is gitignored — never commit real secrets.

# Flask session secret.  Use any long random string locally.
SECRET_KEY=replace-me-with-a-long-random-string

# Leave this unset locally to use the default SQLite database (instance/musicianship.db).
# Set it to a Postgres URL if you want to test against a local Postgres instance.
# DATABASE_URL=postgresql://user:password@localhost:5432/musicianship
